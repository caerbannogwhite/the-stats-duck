# Stata DTA format
query TTTTTTT
SELECT mychar, ROUND(mynum, 1), mydate, dtime, ROUND(mylabl, 1), ROUND(myord, 1), mytime
FROM read_stat('./test/data/sample.dta')
----
a	1.1	2018-05-06	2018-05-06 10:10:10	1.0	1.0	10:10:10
b	1.2	1880-05-06	1880-05-06 10:10:10	2.0	2.0	23:10:10
c	-1000.3	1960-01-01	1960-01-01 00:00:00	1.0	3.0	00:00:00
d	-1.4	1583-01-01	1583-01-01 00:00:00	2.0	1.0	16:10:10
e	1000.3	NULL	NULL	1.0	1.0	NULL

# Explicit format parameter
query T
SELECT mychar FROM read_stat('./test/data/sample.sav', format := 'sav') LIMIT 1
----
a

# Replacement scan
query T
SELECT mychar FROM './test/data/sample.sas7bdat' LIMIT 1
----
a

# Missing values (SPSS)
query T
SELECT COUNT(*) FROM read_stat('./test/data/sample_missing.sav')
----
7

# Rows 6-7 have NULL numeric values
query T
SELECT mychar FROM read_stat('./test/data/sample_missing.sav') WHERE mynum IS NULL
----
Z
(empty)

# CDISC trial summary XPT (real-world file with 6 columns, 33 rows)
query I
SELECT COUNT(*) FROM read_stat('./test/data/ts.xpt')
----
33

query TT
SELECT STUDYID, TSPARMCD FROM read_stat('./test/data/ts.xpt') LIMIT 3
----
CDISCPILOT01	ADDON
CDISCPILOT01	AGEMAX
CDISCPILOT01	AGEMIN

# Invalid file (HTML 404 error page saved with .xpt extension) — must error, not crash
statement error
SELECT * FROM read_stat('./test/data/lab1_0_1refrangesampledata.xpt')
