# name: test/sql/read_stat.test
# description: read_stat function — format interoperability
# group: [stats_duck]

require stats_duck

# SAS7BDAT format
query TTTTTTT
SELECT mychar, ROUND(mynum, 1), mydate, dtime, ROUND(mylabl, 1), ROUND(myord, 1), mytime
FROM read_stat('./test/data/sample.sas7bdat')
----
a	1.1	2018-05-06	2018-05-06 10:10:10	1.0	1.0	10:10:10
b	1.2	1880-05-06	1880-05-06 10:10:10	2.0	2.0	23:10:10
c	-1000.3	1960-01-01	1960-01-01 00:00:00	1.0	3.0	00:00:00
d	-1.4	1583-01-01	1583-01-01 00:00:00	2.0	1.0	16:10:10
e	1000.3	NULL	NULL	1.0	1.0	NULL

# SAS transport (XPT) format
query TTTTTTT
SELECT mychar, ROUND(mynum, 1), mydate, dtime, ROUND(mylabl, 1), ROUND(myord, 1), mytime
FROM read_stat('./test/data/sample.xpt')
----
a	1.1	2018-05-06	2018-05-06 10:10:10	1.0	1.0	10:10:10
b	1.2	1880-05-06	1880-05-06 10:10:10	2.0	2.0	23:10:10
c	-1000.3	1960-01-01	1960-01-01 00:00:00	1.0	3.0	00:00:00
d	-1.4	1583-01-01	1583-01-01 00:00:00	2.0	1.0	16:10:10
e	1000.3	NULL	NULL	1.0	1.0	NULL

# SPSS SAV format
query TTTTTTT
SELECT mychar, ROUND(mynum, 1), mydate, dtime, ROUND(mylabl, 1), ROUND(myord, 1), mytime
FROM read_stat('./test/data/sample.sav')
----
a	1.1	2018-05-06	2018-05-06 10:10:10	1.0	1.0	10:10:10
b	1.2	1880-05-06	1880-05-06 10:10:10	2.0	2.0	23:10:10
c	-1000.3	1960-01-01	1960-01-01 00:00:00	1.0	3.0	00:00:00
d	-1.4	1583-01-01	1583-01-01 00:00:00	2.0	1.0	16:10:10
e	1000.3	NULL	NULL	1.0	1.0	NULL

# SPSS POR format
query TTTTTTT
SELECT mychar, ROUND(mynum, 1), mydate, dtime, ROUND(mylabl, 1), ROUND(myord, 1), mytime
FROM read_stat('./test/data/sample.por')
----
a	1.1	2018-05-06	2018-05-06 10:10:10	1.0	1.0	10:10:10
